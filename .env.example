# Variables de entorno para Laboria-V2
# Copia este archivo a .env y configura los valores reales

# APIs de Empleo (puedes configurar múltiples)
# API 1 - Adzuna (habilitada por defecto)
VITE_JOBS_API_1_URL=https://api.adzuna.com/v1/api/jobs/es/search/1
VITE_JOBS_API_1_APP_ID=tu_app_id_aqui
VITE_JOBS_API_1_KEY=tu_api_key_aqui

# API 2 - InfoJobs (desactivada por defecto, requiere API KEY)
VITE_JOBS_API_2_URL=https://api.infojobs.net/api/1/offer
VITE_JOBS_API_2_KEY=tu_api_key_infojobs_aqui

# API 3 - LinkedIn (desactivada por defecto, requiere API KEY)
VITE_JOBS_API_3_URL=https://api.linkedin.com/v2/jobs
VITE_JOBS_API_3_KEY=tu_api_key_linkedin_aqui

# APIs de Cursos (puedes configurar múltiples)
# API 1 - Khan Academy (habilitada por defecto, pública sin autenticación)
VITE_COURSES_API_1_URL=https://www.khanacademy.org/api/v1/topic/root
VITE_COURSES_API_1_KEY=

# API 2 - Coursera (desactivada por defecto, requiere API KEY)
VITE_COURSES_API_2_URL=https://api.coursera.org/api/courses.v1
VITE_COURSES_API_2_KEY=tu_api_key_coursera_aqui

# API 3 - Udemy (desactivada por defecto, requiere API KEY)
VITE_COURSES_API_3_URL=https://www.udemy.com/api-2.0/courses
VITE_COURSES_API_3_KEY=tu_api_key_udemy_aqui

# Notas:
# - Las variables que empiezan con VITE_ están disponibles en el código frontend
# - No incluyas .env en el control de versiones (ya está en .gitignore)
# - Usa API keys de prueba/desarrollo para desarrollo
# - Para producción, configura las variables en tu entorno de hosting
# - Para habilitar una API adicional, configura su URL y API KEY
# - El sistema buscará en todas las APIs habilitadas y combinará los resultados
# - Adzuna requiere tanto APP_ID como API_KEY para funcionar
# - Khan Academy es pública y no requiere autenticación
# - InfoJobs, LinkedIn, Coursera y Udemy requieren registro para obtener API keys
